# 1Password secret references for OpenClaw.
# Copy to `.env.1password` at repo root and replace the vault/item/field names with your own.
# Format: op://<Vault>/<Item>/<Field>

# Core models
OPENAI_API_KEY=op://OpenClaw/openclaw-prod/OPENAI_API_KEY
ANTHROPIC_API_KEY=op://OpenClaw/openclaw-prod/ANTHROPIC_API_KEY

# Research market data
MASSIVE_API_KEY=op://OpenClaw/openclaw-prod/MASSIVE_API_KEY
POLYGON_API_KEY=op://OpenClaw/openclaw-prod/POLYGON_API_KEY
ALPHA_VANTAGE_API_KEY=op://OpenClaw/openclaw-prod/ALPHA_VANTAGE_API_KEY
ALPHAVANTAGE_API_KEY=op://OpenClaw/openclaw-prod/ALPHAVANTAGE_API_KEY
FRED_API_KEY=op://OpenClaw/openclaw-prod/FRED_API_KEY
SEC_USER_AGENT=op://OpenClaw/openclaw-prod/SEC_USER_AGENT

# Channels
TELEGRAM_BOT_TOKEN=op://OpenClaw/openclaw-prod/TELEGRAM_BOT_TOKEN

# Research gated-source cookies
OPENCLAW_RESEARCH_SUBSTACK_COOKIE=op://OpenClaw/openclaw-prod/OPENCLAW_RESEARCH_SUBSTACK_COOKIE
OPENCLAW_RESEARCH_STRATECHERY_COOKIE=op://OpenClaw/openclaw-prod/OPENCLAW_RESEARCH_STRATECHERY_COOKIE
OPENCLAW_RESEARCH_DIFF_COOKIE=op://OpenClaw/openclaw-prod/OPENCLAW_RESEARCH_DIFF_COOKIE
OPENCLAW_RESEARCH_SEMIANALYSIS_COOKIE=op://OpenClaw/openclaw-prod/OPENCLAW_RESEARCH_SEMIANALYSIS_COOKIE

# Security
RESEARCH_PROVENANCE_SECRET=op://OpenClaw/openclaw-prod/RESEARCH_PROVENANCE_SECRET
OPENCLAW_GATEWAY_TOKEN=op://OpenClaw/openclaw-prod/OPENCLAW_GATEWAY_TOKEN
