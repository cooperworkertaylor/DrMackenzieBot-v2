# Copy to .env and fill with your Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Must be a WhatsApp-enabled Twilio number, prefixed with whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+17343367101

# Supabase research runtime
OPENCLAW_SUPABASE_URL=https://ufnjzzkwmuolbubckawl.supabase.co
OPENCLAW_SUPABASE_ANON_KEY=
OPENCLAW_SUPABASE_SERVICE_ROLE_KEY=

# Research ingestion (email + newsletters)
# Gmail senders allowed to auto-ingest RESEARCH subject emails
OPENCLAW_RESEARCH_EMAIL_ALLOW_SENDERS=cooptaylor1@gmail.com,ct@salemcounsel.com
# Gmail senders force-ingested as email_research regardless of subject/provider
OPENCLAW_RESEARCH_EMAIL_FORCE_SENDERS=ct@salemcounsel.com
# Subject prefix for direct research ingestion emails
OPENCLAW_RESEARCH_EMAIL_SUBJECT_PREFIX=RESEARCH
# When true, Gmail hook ingestion skips normal agent reply flow
OPENCLAW_RESEARCH_EMAIL_INGEST_SKIP_AGENT=true

# Newsletter source registry (format: provider|url|optionalTicker;provider|url|optionalTicker)
# provider should be one of: substack,stratechery,diff,semianalysis,other
OPENCLAW_RESEARCH_NEWSLETTER_SOURCES=
# Optional provider-specific archive lists (comma-separated URLs)
OPENCLAW_RESEARCH_SUBSTACK_ARCHIVES=
OPENCLAW_RESEARCH_STRATECHERY_ARCHIVES=
OPENCLAW_RESEARCH_DIFF_ARCHIVES=
OPENCLAW_RESEARCH_SEMIANALYSIS_ARCHIVES=

# Auth cookies for paywalled newsletter crawling
OPENCLAW_RESEARCH_SUBSTACK_COOKIE=
OPENCLAW_RESEARCH_STRATECHERY_COOKIE=
OPENCLAW_RESEARCH_DIFF_COOKIE=
OPENCLAW_RESEARCH_SEMIANALYSIS_COOKIE=
# Optional fallback cookie applied to all providers if provider-specific cookie is empty
OPENCLAW_RESEARCH_NEWSLETTER_COOKIE=
